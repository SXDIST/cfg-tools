{
  "name": "cfg-tools",
  "version": "2.0.0",
  "private": true,
  "description": "Desktop DayZ config generator",
  "author": "SXDIST",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "dev:electron": "wait-on tcp:3000 && cross-env DEV_SERVER_URL=http://localhost:3000 electron .",
    "dev:desktop": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "start": "electron .",
    "start:web": "next start",
    "build": "next build",
    "build:web": "next build",
    "build:desktop": "npm run build:web && electron-builder",
    "build:desktop:linux": "npm run build:web && electron-builder --linux tar.gz",
    "build:desktop:win": "npm run build:web && electron-builder --win portable nsis",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.576.0",
    "next": "^16.1.7",
    "postcss": "^8.5.8",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.7.1",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.sxdist.cfgtools",
    "productName": "cfg-tools",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "out/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "tar.gz"
      ]
    }
  }
}
