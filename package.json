{
  "name": "cfg-tools",
  "version": "2.1.0",
  "private": true,
  "description": "Desktop DayZ config generator",
  "author": "SXDIST",
  "scripts": {
    "dev": "next dev",
    "dev:web": "next dev",
    "sync:wails-version": "node scripts/sync-wails-version.mjs",
    "dev:desktop": "npm run sync:wails-version && wails dev",
    "start": "wails dev",
    "start:web": "next start",
    "build": "next build",
    "build:web": "next build && node scripts/clean-export.mjs",
    "build:desktop": "npm run sync:wails-version && wails build -clean",
    "build:desktop:linux": "npm run sync:wails-version && wails build -clean -tags webkit2_41",
    "build:desktop:win": "npm run sync:wails-version && wails build -clean -nsis -webview2 download",
    "lint": "eslint",
    "release": "node scripts/release.mjs",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.576.0",
    "next": "^16.1.7",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-resizable-panels": "^4",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "postcss": "^8.5.8",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
